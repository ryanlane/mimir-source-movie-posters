{
  "id": "com.mimir.movieposters",
  "name": "Movie Posters",
  "description": "Displays random movie posters from The Movie Database (TMDB). Supports genre and curated list sub-channels. Requires a free TMDB API key.",
  "version": "1.0.0",
  "type": "embedded",
  "entry_point": "channel.py",
  "class_name": "MoviePostersChannel",
  "icon": "film",
  "author": "Ryan Lane",
  "tags": [
    "movies",
    "posters",
    "art",
    "tmdb",
    "cinema"
  ],
  "schemaVersion": "2.4",
  "settingsType": "advanced",
  "config": {
    "supports_upload": false,
    "supports_subchannels": true,
    "requires_api_key": true
  },
  "requirements": {
    "python": ">=3.8",
    "dependencies": [
      "fastapi",
      "pillow",
      "requests"
    ]
  },
  "user_data_dirs": [
    "data"
  ],
  "update_schedule": {
    "unit": "hours",
    "duration": 1,
    "settings_driven": false
  },
  "settings": {
    "defaults": {
      "api_key": "",
      "poster_size": "w780",
      "fit_mode": "letterbox",
      "cache_max_per_source": 500,
      "refresh_interval_hours": 168,
      "min_vote_count": 50,
      "include_adult": false
    },
    "schema": {
      "type": "object",
      "properties": {
        "api_key": {
          "type": "string",
          "title": "TMDB API Key",
          "description": "Your TMDB v3 API key from themoviedb.org/settings/api"
        },
        "poster_size": {
          "type": "string",
          "enum": ["w342", "w500", "w780", "original"],
          "title": "Poster Size",
          "description": "TMDB image size to request",
          "default": "w780"
        },
        "fit_mode": {
          "type": "string",
          "enum": ["letterbox", "crop", "stretch"],
          "title": "Fit Mode",
          "default": "letterbox"
        },
        "cache_max_per_source": {
          "type": "integer",
          "minimum": 50,
          "maximum": 2000,
          "title": "Max Posters per Source",
          "default": 500
        },
        "refresh_interval_hours": {
          "type": "integer",
          "minimum": 1,
          "title": "Cache Refresh Interval (hours)",
          "description": "How often to re-fetch the poster list from TMDB (default: weekly)",
          "default": 168
        },
        "min_vote_count": {
          "type": "integer",
          "minimum": 0,
          "title": "Minimum Vote Count",
          "description": "Filter out movies with fewer votes (reduces obscure titles)",
          "default": 50
        },
        "include_adult": {
          "type": "boolean",
          "title": "Include Adult Titles",
          "default": false
        }
      }
    }
  },
  "endpoints": [
    { "path": "/manifest", "method": "GET", "description": "Get channel manifest and capabilities" },
    { "path": "/subchannels", "method": "GET", "description": "List configured sources" },
    { "path": "/request-image", "method": "POST", "description": "Get a random movie poster as raw image bytes" },
    { "path": "/settings", "method": "GET", "description": "Get channel settings" },
    { "path": "/settings", "method": "PUT", "description": "Update channel settings" },
    { "path": "/status", "method": "GET", "description": "Get cache and source status" },
    { "path": "/refresh", "method": "POST", "description": "Trigger poster cache refresh" },
    { "path": "/validate-key", "method": "POST", "description": "Validate a TMDB API key" },
    { "path": "/genres", "method": "GET", "description": "List available TMDB genres" }
  ]
}
